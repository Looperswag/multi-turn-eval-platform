# --- DB / Cache ---
DATABASE_URL=postgresql+psycopg://eval:eval@postgres:5432/eval_platform
REDIS_URL=redis://redis:6379/0

# --- API ---
API_KEY=dev-key-change-me
# C.4: 全局鉴权开关。内网/dev 留 false；生产/外网设 true 启用 X-API-Key
REQUIRE_API_KEY=false

# --- Judge models ---
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_DEFAULT_MODEL=doubao-seed-2-0-pro-260215

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Eval engine ---
DEFAULT_JUDGE_TEMPERATURE=0.1
DEFAULT_MAX_CONCURRENT_REQUESTS=5
DEFAULT_REQUEST_INTERVAL_SEC=0.5
DEFAULT_MAX_RETRIES=3
